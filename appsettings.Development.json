{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AlgorithmPick.Middleware.RateLimiting": "Debug"
    }
  },
  "RateLimit": {
    "Algorithm": "TokenBucket",
    "RequestsPerSecond": 5,
    "Capacity": 10,
    "StatusCode": 429,
    "Message": "开发环境：请求过于频繁，请稍后再试",
    "IncludeHeaders": true
  }
}
